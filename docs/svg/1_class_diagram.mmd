classDiagram
    direction LR

    %% ========== AUTH MODULE ==========
    class AuthStrategyFactory {
        +createEmailStrategy(intent)
        +createOAuthStrategy(provider)
    }

    class EmailSignUpStrategy {
        +execute(credentials)
    }

    class EmailSignInStrategy {
        +execute(credentials)
    }

    class GoogleOAuthStrategy {
        +getAuthorizationUrl()
        +completeAuthorization()
        +consumeExchangeCode()
    }

    %% ========== MATCHING MODULE ==========
    class MatchingService {
        -eligibilityStrategy
        -scoringStrategy
        +findMatchesForUser(userId)
    }

    class DefaultEligibilityStrategy {
        +isEligible(userA, userB)
    }

    class DefaultScoringStrategy {
        +calculateScore(prefA, prefB)
    }

    %% ========== CORE SERVICES ==========
    class DiscoveryService {
        +getDiscoveryFeed(userId)
        +swipeUser(fromId, toId, action)
    }

    class MatchesService {
        +checkAndCreateMatch(fromId, toId)
        +getMyMatches(userId)
    }

    class ProfileService {
        +getProfileByUserId(userId)
        +createOrUpdateProfile(userId, data)
    }

    class PreferencesService {
        +getPreferences(userId)
        +savePreferences(userId, data)
    }

    class ChatService {
        +getOrCreateConversation(matchId)
        +sendMessage(convoId, senderId, content)
    }

    %% ========== TEMPLATE METHOD ==========
    class UpsertByUserIdService {
        <<abstract>>
        +upsert(userId, data)*
    }

    class ProfileUpsertService {
        +upsert(userId, data)
    }

    class PreferenceUpsertService {
        +upsert(userId, data)
    }

    %% ========== FRONTEND API ==========
    class HttpClientAdapter {
        -strategy
        +request(config)
    }

    class FetchRequestStrategy {
        +send(request)
    }

    %% ========== RELATIONSHIPS ==========
    
    %% Auth Factory creates strategies
    AuthStrategyFactory ..> EmailSignUpStrategy : creates
    AuthStrategyFactory ..> EmailSignInStrategy : creates
    AuthStrategyFactory ..> GoogleOAuthStrategy : creates

    %% Matching uses strategies
    MatchingService o-- DefaultEligibilityStrategy : uses
    MatchingService o-- DefaultScoringStrategy : uses

    %% Discovery orchestrates
    DiscoveryService --> MatchingService : ranks candidates
    DiscoveryService --> MatchesService : creates matches

    %% Matches uses matching
    MatchesService --> MatchingService : calculates scores

    %% Template Method pattern
    UpsertByUserIdService <|-- ProfileUpsertService : extends
    UpsertByUserIdService <|-- PreferenceUpsertService : extends
    ProfileService --> ProfileUpsertService : delegates
    PreferencesService --> PreferenceUpsertService : delegates

    %% Frontend Adapter pattern
    HttpClientAdapter o-- FetchRequestStrategy : uses
